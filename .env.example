# Copiar a .env.local para desarrollo local
# PostgreSQL: docker compose up -d  (ver docker-compose.yml)

DATABASE_URL="postgresql://emprenor:emprenor_local@localhost:5432/emprenor?schema=public"
# Neon / Vercel: URL directa sin pooler (prisma db push / migraciones)
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST/neondb?sslmode=require"

NEXTAUTH_SECRET="generar-string-aleatorio-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3001"
PORT=3001

# AWS S3 documentos (opcional en local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=emprenor/

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Cron (POST /api/cron/maintenance)
CRON_SECRET=

# Vercel Blob (opcional)
BLOB_READ_WRITE_TOKEN=

# NOTA: El stack Nexus usa PostgreSQL + Prisma, no MongoDB.
# Produccion remota: ver .env.production (Abacus)
