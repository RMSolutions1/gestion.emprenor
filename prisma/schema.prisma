generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
  PLATFORM_OWNER
  ADMIN
  CLIENTE
  INGENIERO_CIVIL
  ARQUITECTO
  INGENIERO_ELECTRICO
  INSPECTOR_CALIDAD
  INSPECTOR_OBRA
}

enum ClientEntityType {
  PARTICULAR
  EMPRESA
  COMERCIO
  INDUSTRIA
  PUBLICO
  CONSORCIO
  FUNDACION
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ProjectStatus {
  PLANIFICACION
  EN_CURSO
  PAUSADO
  FINALIZADO
}

enum SiteType {
  OBRA_GENERAL
  BARRIO_PRIVADO
  INDUSTRIA
  COMERCIAL
  RESIDENCIAL
  OIL_GAS
  MINERIA
  ENERGIA
  AGRO
  INFRAESTRUCTURA
  SERVICIOS_PUBLICOS
}

enum DocumentCategory {
  PLANOS
  FACTURAS
  REMITOS
  ORDENES_TRABAJO
  PROCEDIMIENTOS
  ART
  SEGUROS
  LEGAJO_PERSONAL
  VEHICULO
  ADICIONAL_OBRA
  ANTECEDENTES
  LISTA_MATERIALES
  INFORME_TECNICO
  CONFORMIDAD
  OTROS
}

enum IncidentStatus {
  PENDIENTE
  EN_PROCESO
  RESUELTA
}

enum WorkExtraStatus {
  BORRADOR
  PENDIENTE_CLIENTE
  APROBADO
  RECHAZADO
  EN_EJECUCION
  COMPLETADO
}

enum BackgroundCheckStatus {
  NO_APLICA
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum MaterialCategory {
  HERRAMIENTA
  MATERIAL
  EPP
  EQUIPO
  OTRO
}

enum MaterialDeliveryStatus {
  PENDIENTE
  PARCIAL
  ENTREGADO
}

enum SiteLogPhase {
  ANTES
  DURANTE
  DESPUES
}

enum LedgerEntryType {
  PRESUPUESTO
  ADICIONAL
  FACTURA
  PAGO
  AJUSTE
  NOTA_CREDITO
}

enum TaskPriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum ProjectTaskStatus {
  PENDIENTE
  EN_CURSO
  BLOQUEADA
  HECHA
  CANCELADA
}

enum MilestoneStatus {
  PENDIENTE
  EN_CURSO
  COMPLETADO
  ATRASADO
}

enum TechnicalReportType {
  INFORME
  CONFORMIDAD
  NO_CONFORMIDAD
  SOLICITUD_CORRECCION
  ACTA_INSPECCION
}

enum TechnicalReportStatus {
  BORRADOR
  PENDIENTE_CLIENTE
  APROBADO
  RECHAZADO
  EN_CORRECCION
}

enum LiveFeedEventType {
  PROJECT_UPDATED
  DOCUMENT_UPLOADED
  WORKER_ADDED
  VEHICLE_ADDED
  INCIDENT_CREATED
  REPORT_SUBMITTED
  REPORT_APPROVED
  REPORT_REJECTED
  EXTRA_PENDING
  EXTRA_APPROVED
  COMPLIANCE_ALERT
  CHAT_MESSAGE
  WORK_ORDER_CREATED
  NC_CREATED
  HSE_INCIDENT
  SYSTEM
}

enum NotificationType {
  APPROVAL_REQUIRED
  COMPLIANCE_EXPIRY
  INCIDENT
  DOCUMENT
  REPORT
  CHAT
  SYSTEM
}

enum ChatChannelType {
  ORGANIZATION
  PROJECT
  DIRECT
}

enum MessagePriority {
  NORMAL
  HIGH
  URGENT
}

enum WorkOrderStatus {
  BORRADOR
  ASIGNADA
  EN_EJECUCION
  PENDIENTE_APROBACION
  COMPLETADA
  CANCELADA
}

enum NcStatus {
  ABIERTA
  EN_TRATAMIENTO
  CERRADA
}

enum CapaType {
  CORRECTIVA
  PREVENTIVA
}

enum CapaStatus {
  PENDIENTE
  EN_CURSO
  VERIFICADA
  CERRADA
}

enum HseIncidentSeverity {
  LEVE
  MODERADO
  GRAVE
  FATAL
}

enum PermitToWorkStatus {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADO
  EN_CURSO
  CERRADO
  RECHAZADO
}

enum SafetyInspectionResult {
  CONFORME
  NO_CONFORME
  OBSERVACION
}

enum OcrStatus {
  SKIPPED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  legalName            String?
  plan                 TenantPlan         @default(STARTER)
  status               OrganizationStatus @default(TRIAL)
  customDomain         String?            @unique
  country              String             @default("AR")
  industry             String?
  billingEmail         String?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  branding     TenantBranding?
  users        User[]
  projects     Project[]
  chatChannels ChatChannel[]
  workOrders   WorkOrder[]
  pacDocuments TenantPacDocument[]

  @@index([status])
  @@index([slug])
}

model TenantPacDocument {
  id               String       @id @default(cuid())
  organizationId   String
  code             String
  title            String
  revision         String?
  fileName         String
  cloudStoragePath String
  uploadedAt       DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([code])
}

model TenantBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String       @default("#1e40af")
  secondaryColor String       @default("#f97316")
  accentColor    String       @default("#0f172a")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  password        String
  name            String
  role            Role                @default(CLIENTE)
  organizationId  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assignments      ProjectAssignment[]
  technicalReports TechnicalReport[]
  notifications    Notification[]
  chatMessages     ChatMessage[]
  chatMemberships  ChatChannelMember[]
  workOrdersCreated WorkOrder[]       @relation("WorkOrderCreator")
  workOrdersAssigned WorkOrder[]      @relation("WorkOrderAssignee")
  qualityNCs       QualityNonConformance[]
  capasOwned         CorrectiveAction[]
  hseIncidents       HseIncident[]
  documentVersions   DocumentVersion[]
  documentsSigned    Document[]        @relation("DocumentSigner")
  workExtrasApproved WorkExtra[]       @relation("WorkExtraApprover")
  receptionsSigned   Project[]         @relation("ProjectReceptionSigner")
  ledgerEntries      ProjectLedgerEntry[]
  siteLogEntries     SiteLogEntry[]
  tasksAssigned      ProjectTask[]       @relation("TaskAssignee")
  tasksCreated       ProjectTask[]       @relation("TaskCreator")
  dailyFieldReports  DailyFieldReport[]
  clientProfile      ClientProfile?

  @@index([organizationId])
}

model ClientProfile {
  id             String           @id @default(cuid())
  userId         String           @unique
  entityType     ClientEntityType @default(EMPRESA)
  legalName      String?
  taxId          String?
  phone          String?
  mobilePhone    String?
  contactRole    String?
  billingAddress String?
  city           String?
  province       String?
  postalCode     String?
  country        String           @default("AR")
  sector         String?
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType])
  @@index([taxId])
}

model Project {
  id                    String              @id @default(cuid())
  name                  String
  address               String
  projectType           String
  description           String?             @db.Text
  siteType              SiteType            @default(OBRA_GENERAL)
  siteRequirementsNotes String?             @db.Text
  startDate             DateTime?
  endDate               DateTime?
  status                ProjectStatus       @default(PLANIFICACION)
  budgetAmount          Decimal?            @db.Decimal(14, 2)
  budgetCurrency        String              @default("ARS")
  liabilityInsurancePolicy   String?
  liabilityInsuranceInsurer  String?
  liabilityInsuranceExpiry   DateTime?
  receptionReadyAt           DateTime?
  receptionReference         String?             @unique
  receptionAt                DateTime?
  receptionById              String?
  receptionClientIp          String?
  receptionNotes             String?             @db.Text
  warrantyDays               Int                 @default(120)
  warrantyStartAt            DateTime?
  warrantyEndAt              DateTime?
  organizationId        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  receptionBy           User?               @relation("ProjectReceptionSigner", fields: [receptionById], references: [id], onDelete: SetNull)
  assignments           ProjectAssignment[]
  documents             Document[]
  incidents             Incident[]
  workers               Worker[]
  vehicles              Vehicle[]
  workExtras            WorkExtra[]
  materials             ProjectMaterial[]
  technicalReports      TechnicalReport[]
  liveFeedEvents        LiveFeedEvent[]
  chatChannels          ChatChannel[]
  workOrders            WorkOrder[]
  qualityNCs            QualityNonConformance[]
  hseIncidents          HseIncident[]
  permitsToWork         PermitToWork[]
  safetyInspections     SafetyInspection[]
  ledgerEntries         ProjectLedgerEntry[]
  siteLogEntries        SiteLogEntry[]
  tasks                   ProjectTask[]
  milestones              ProjectMilestone[]
  dailyFieldReports       DailyFieldReport[]

  @@index([organizationId])
  @@index([receptionById])
  @@index([warrantyEndAt])
}

model ProjectTask {
  id          String            @id @default(cuid())
  projectId   String
  title       String
  description String?           @db.Text
  status      ProjectTaskStatus @default(PENDIENTE)
  priority    TaskPriority      @default(MEDIA)
  dueAt       DateTime?
  assigneeId  String?
  createdById String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User?             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([assigneeId])
}

model ProjectMilestone {
  id               String          @id @default(cuid())
  projectId        String
  name             String
  description      String?         @db.Text
  dueDate          DateTime?
  percentComplete  Int             @default(0)
  status           MilestoneStatus @default(PENDIENTE)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
}

model DailyFieldReport {
  id          String   @id @default(cuid())
  projectId   String
  reportDate  DateTime @default(now())
  weather     String?
  crewCount   Int?
  summary     String   @db.Text
  blockers    String?  @db.Text
  nextSteps   String?  @db.Text
  authorId    String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([reportDate])
}

model LiveFeedEvent {
  id        String            @id @default(cuid())
  projectId String?
  type      LiveFeedEventType
  title     String
  body      String?           @db.Text
  metadata  Json?
  actorId   String?
  createdAt DateTime          @default(now())
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?          @db.Text
  link      String?
  read      Boolean          @default(false)
  projectId String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  organizationId String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([resource, resourceId])
  @@index([actorId])
  @@index([organizationId])
}

model PlatformMetric {
  id        String   @id @default(cuid())
  key       String
  value     Decimal  @db.Decimal(18, 4)
  period    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([key, period])
  @@index([key])
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Document {
  id                String           @id @default(cuid())
  fileName          String
  cloudStoragePath  String
  isPublic          Boolean          @default(false)
  category          DocumentCategory
  projectId         String
  version           Int              @default(1)
  ocrStatus         OcrStatus        @default(SKIPPED)
  ocrText           String?          @db.Text
  ocrProcessedAt    DateTime?
  signedAt          DateTime?
  signedById        String?
  signatureNote     String?          @db.Text
  workerId          String?
  vehicleId         String?
  workExtraId       String?
  projectMaterialId String?
  uploadedAt        DateTime         @default(now())
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectMaterial   ProjectMaterial? @relation(fields: [projectMaterialId], references: [id], onDelete: SetNull)
  signedBy          User?            @relation("DocumentSigner", fields: [signedById], references: [id], onDelete: SetNull)
  worker            Worker?          @relation(fields: [workerId], references: [id], onDelete: SetNull)
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  workExtra         WorkExtra?       @relation(fields: [workExtraId], references: [id], onDelete: SetNull)
  versions          DocumentVersion[]

  @@index([projectId])
  @@index([category])
  @@index([workerId])
  @@index([vehicleId])
  @@index([ocrStatus])
  @@index([signedById])
  @@index([projectMaterialId])
}

model DocumentVersion {
  id               String   @id @default(cuid())
  documentId       String
  versionNumber    Int
  fileName         String
  cloudStoragePath String
  uploadedById     String?
  changeNote       String?  @db.Text
  uploadedAt       DateTime @default(now())
  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy       User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model Incident {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  status      IncidentStatus @default(PENDIENTE)
  projectId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model Worker {
  id                    String                @id @default(cuid())
  name                  String
  workerRole            String
  certifications        String?               @db.Text
  dni                   String?
  cuil                  String?
  cuit                  String?
  artNumber             String?
  artExpiry             DateTime?
  lifeInsuranceExpiry   DateTime?
  eppComplete           Boolean               @default(false)
  backgroundCheckStatus BackgroundCheckStatus @default(NO_APLICA)
  backgroundCheckDate   DateTime?
  backgroundCheckNotes  String?               @db.Text
  habilitationNotes     String?               @db.Text
  complianceNotes       String?               @db.Text
  projectId             String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents             Document[]
  materials             ProjectMaterial[]

  @@index([projectId])
}

model Vehicle {
  id                      String     @id @default(cuid())
  label                   String
  plate                   String?
  driverName              String?
  driverLicense           String?
  driverLicenseExpiry     DateTime?
  technicalReviewExpiry   DateTime?
  insuranceExpiry         DateTime?
  artExpiry               DateTime?
  notes                   String?    @db.Text
  projectId               String
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  project                 Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents               Document[]

  @@index([projectId])
}

model WorkExtra {
  id                 String          @id @default(cuid())
  title              String
  description        String?         @db.Text
  amount             Decimal         @db.Decimal(14, 2)
  status             WorkExtraStatus @default(PENDIENTE_CLIENTE)
  approvalReference  String?         @unique
  approvedAt         DateTime?
  approvedById       String?
  rejectedAt         DateTime?
  rejectedById       String?
  clientApprovalIp   String?
  executedAt         DateTime?
  completedAt        DateTime?
  projectId          String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy         User?           @relation("WorkExtraApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  documents          Document[]
  workOrders         WorkOrder[]

  @@index([projectId])
  @@index([status])
  @@index([approvedById])
}

model ProjectMaterial {
  id               String                 @id @default(cuid())
  itemName         String
  quantity         String?
  unit             String?
  category         MaterialCategory       @default(MATERIAL)
  supplier         String?
  brand            String?
  unitPrice        Decimal?               @db.Decimal(14, 2)
  deliveryStatus   MaterialDeliveryStatus @default(PENDIENTE)
  receivedQuantity String?
  notes            String?                @db.Text
  projectId        String
  workerId         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker           Worker?                @relation(fields: [workerId], references: [id], onDelete: SetNull)
  documents        Document[]

  @@index([projectId])
  @@index([category])
  @@index([deliveryStatus])
}

model ProjectLedgerEntry {
  id          String          @id @default(cuid())
  projectId   String
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(14, 2)
  currency    String          @default("ARS")
  description String
  reference   String?
  workExtraId String?
  documentId  String?
  createdById String?
  createdAt   DateTime        @default(now())
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

model SiteLogEntry {
  id               String       @id @default(cuid())
  projectId        String
  phase            SiteLogPhase
  title            String
  notes            String?      @db.Text
  fileName         String?
  cloudStoragePath String?
  latitude         Float?
  longitude        Float?
  uploadedById     String?
  createdAt        DateTime     @default(now())
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User?        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phase])
  @@index([createdAt])
}

model TechnicalReport {
  id                    String                @id @default(cuid())
  title                 String
  description           String?               @db.Text
  reportType            TechnicalReportType
  status                TechnicalReportStatus @default(BORRADOR)
  requiresClientApproval Boolean              @default(true)
  projectId             String
  authorId              String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author                User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([authorId])
  @@index([status])
  @@index([reportType])
}

model ChatChannel {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String?
  type           ChatChannelType
  name           String
  description    String?         @db.Text
  dmKey          String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
  members        ChatChannelMember[]

  @@index([organizationId])
  @@index([projectId])
  @@index([type])
}

model ChatChannelMember {
  id        String      @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime    @default(now())
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChatMessage {
  id         String          @id @default(cuid())
  channelId  String
  authorId   String
  body       String          @db.Text
  parentId   String?
  priority   MessagePriority @default(NORMAL)
  metadata   Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  channel    ChatChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author     User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     ChatMessage?    @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies    ChatMessage[]   @relation("MessageThread")
  attachments ChatAttachment[]

  @@index([channelId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model ChatAttachment {
  id        String      @id @default(cuid())
  messageId String
  fileName  String
  url       String
  mimeType  String?
  sizeBytes Int?
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model WorkOrder {
  id              String          @id @default(cuid())
  organizationId  String
  projectId       String
  number          String
  title           String
  description     String?         @db.Text
  status          WorkOrderStatus @default(BORRADOR)
  assigneeId      String?
  createdById     String
  slaDueAt        DateTime?
  estimatedCost   Decimal?        @db.Decimal(14, 2)
  actualCost      Decimal?        @db.Decimal(14, 2)
  checklist       Json?
  gpsLat          Float?
  gpsLng          Float?
  clientApproved  Boolean         @default(false)
  workExtraId     String?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workExtra       WorkExtra?      @relation(fields: [workExtraId], references: [id], onDelete: SetNull)
  assignee        User?           @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy       User            @relation("WorkOrderCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([organizationId, number])
  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
  @@index([workExtraId])
}

model QualityNonConformance {
  id               String    @id @default(cuid())
  organizationId   String
  projectId        String
  code             String
  title            String
  description      String?   @db.Text
  status           NcStatus  @default(ABIERTA)
  rootCause        String?   @db.Text
  isoClause        String?
  detectedAt       DateTime  @default(now())
  dueDate          DateTime?
  closedAt         DateTime?
  authorId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  correctiveActions CorrectiveAction[]

  @@unique([projectId, code])
  @@index([organizationId])
  @@index([status])
}

model CorrectiveAction {
  id          String     @id @default(cuid())
  ncId        String
  type        CapaType
  title       String
  description String?    @db.Text
  status      CapaStatus @default(PENDIENTE)
  ownerId     String
  dueDate     DateTime?
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  nc          QualityNonConformance @relation(fields: [ncId], references: [id], onDelete: Cascade)
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ncId])
  @@index([status])
}

model HseIncident {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  description    String?             @db.Text
  severity       HseIncidentSeverity @default(LEVE)
  injuredCount   Int                 @default(0)
  workStoppage   Boolean             @default(false)
  investigation  String?             @db.Text
  reportedAt     DateTime            @default(now())
  closedAt       DateTime?
  reporterId     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter       User                @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([severity])
}

model PermitToWork {
  id             String             @id @default(cuid())
  organizationId String
  projectId      String
  permitNumber   String
  workType       String
  location       String?
  description    String?            @db.Text
  status         PermitToWorkStatus @default(BORRADOR)
  validFrom      DateTime?
  validUntil     DateTime?
  approverNotes  String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, permitNumber])
  @@index([status])
}

model SafetyInspection {
  id             String                 @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  checklist      Json?
  result         SafetyInspectionResult @default(CONFORME)
  observations   String?                @db.Text
  inspectedAt    DateTime               @default(now())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([result])
}
